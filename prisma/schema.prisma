generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id        String   @id @default(uuid())
  name      String
  email     String
  strategy  String
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  plan          String    @default("FREE") // FREE, BASIC, PREMIUM
  createdAt     DateTime  @default(now())
  strategies    Strategy[]
  licenses      License[]
}

model Strategy {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  prompt        String
  status        String    @default("PENDING") // PENDING, BACKTESTING, COMPLETED, FAILED
  sourceCode    String?
  platform      String    @default("MT5")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  results       BacktestResult?
}

model BacktestResult {
  id            String    @id @default(cuid())
  strategyId    String    @unique
  strategy      Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  winRate       Float?
  profitFactor  Float?
  maxDrawdown   Float?
  totalTrades   Int?
  equityCurve   String?   // JSON string of equity data points
  createdAt     DateTime  @default(now())
}

model Waitlist {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String
  country       String
  discordId     String
  capital       String
  propFirm      String
  struggle      String
  hesitation    String   @default("Unknown")
  earlyBirdCode String   @unique @default(cuid())
  status        String   @default("PENDING") // PENDING, NOTIFIED, CLAIMED
  createdAt     DateTime @default(now())
}

model License {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  mt5AccountNumber String?  @unique
  product          String   @default("MOMENTUM_PRO")
  status           String   @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED
  createdAt        DateTime @default(now())
}

model Analytics {
  id             String   @id @default("global")
  visits         Int      @default(0)
  waitlistClicks Int      @default(0)
}

model MT5ForwardTest {
  id          String   @id @default("live_account")
  balance     Float    @default(0)
  equity      Float    @default(0)
  profit      Float    @default(0)
  winRate     Float    @default(0)
  drawdown    Float    @default(0)
  equityCurve String   @default("[]") // JSON string of { date, value }
  updatedAt   DateTime @updatedAt
}

model MT5Trade {
  id          String   @id // Ticket number from MT5
  pair        String
  type        String   // BUY or SELL
  profit      Float
  openTime    DateTime
  closeTime   DateTime
  durationMin    Float?
  requestedPrice Float?
  openPrice      Float?
  slippagePts    Float?
  spreadPts      Float?
  brokerHour     Int?
  brokerMinute   Int?
  profitPts      Float?
  maxDrawdownPts Float?
  pipsFromPDH    Float?
}

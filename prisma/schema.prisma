generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Submission {
  id        String   @id @default(uuid())
  name      String
  email     String
  strategy  String
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  password      String?
  plan          String    @default("FREE") // FREE, BASIC, PREMIUM
  createdAt     DateTime  @default(now())
  strategies    Strategy[]
  licenses      License[]
}

model Strategy {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id])
  prompt        String
  status        String    @default("PENDING") // PENDING, BACKTESTING, COMPLETED, FAILED
  sourceCode    String?
  platform      String    @default("MT5")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  results       BacktestResult?
}

model BacktestResult {
  id            String    @id @default(cuid())
  strategyId    String    @unique
  strategy      Strategy  @relation(fields: [strategyId], references: [id], onDelete: Cascade)
  winRate       Float?
  profitFactor  Float?
  maxDrawdown   Float?
  totalTrades   Int?
  equityCurve   String?   // JSON string of equity data points
  createdAt     DateTime  @default(now())
}

model Waitlist {
  id            String   @id @default(uuid())
  name          String
  email         String   @unique
  phone         String
  country       String
  discordId     String
  capital       String
  propFirm      String
  struggle      String
  promoCode     String?
  earlyBirdCode String   @unique @default(cuid())
  status        String   @default("PENDING") // PENDING, NOTIFIED, CLAIMED
  createdAt     DateTime @default(now())
}

model License {
  id               String   @id @default(cuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  mt5AccountNumber String?  @unique
  product          String   @default("MOMENTUM_PRO")
  status           String   @default("ACTIVE") // ACTIVE, REVOKED, EXPIRED
  createdAt        DateTime @default(now())
}
